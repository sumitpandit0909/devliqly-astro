---
import { client } from '../../lib/sanity';
import {services} from '../../config/services.json';
import {parseRichText} from "../../utils/RichTextParser.js"; 

// Fetch all blog slugs for static generation
export async function getStaticPaths() {
  const query = `*[_type == "post"]{ "slug": slug.current }`;
  const posts = await client.fetch(query);

  return posts.map((post:any) => ({
    params: { slug: post.slug },
  }));
}

// Get the slug from Astro params
const { slug } = Astro.params;

// Fetch individual blog post data
const query = `*[_type == "post" && slug.current == $slug][0]{
  title, 
  "image": mainImage.asset->url, 
  publishedAt, 
  Excerpt, 
  body, 
  categories[]->{title}, 
  author->{name}
}`;
const post = await client.fetch(query, { slug });
// console.log(post);
if (!post) {
  throw new Error("Post not found");
}
import Layout from '@/layouts/Layout.astro';
import GeneralHero from '@/components/HeroSections/GeneralHero.astro';
import { Image } from 'astro:assets';
const fetchData = async () => {
    const query = `*[_type == "post"]{
  title, 
  slug, 
  body, 
  "mainImage": mainImage.asset->url, 
  publishedAt, 
  Excerpt, 
  categories[]->{title}, 
  author->{name}
}`;
    return await client.fetch(query);
};

const posts = await fetchData();

